<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER_NAME">
   <children>
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextField fx:id="nombre" promptText="Nombre de tu objeto" GridPane.columnIndex="1" />
            <TextField fx:id="lugar" promptText="Lugar donde fue encontrassdo" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label />
            <Label text="Lugar donde se encontro" GridPane.rowIndex="1" />
            <Label text="Nombre del objeto" />
            <ComboBox fx:id="estado" prefWidth="150.0" promptText="Estado" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button mnemonicParsing="false" text="Agregar" onAction="#Agregar" />
            <Button mnemonicParsing="false" text="Buscar" onAction="#Buscar" />
            <Button mnemonicParsing="false" text="actualizar" onAction="#Actualizar" />
            <Button mnemonicParsing="false" text="Eliminar" onAction="#Eliminar" />
            <Button mnemonicParsing="false" text="Limpiar" onAction="#Limpiar" />
         </children>
      </HBox>
      <ListView fx:id="listview" prefHeight="200.0" prefWidth="200.0" />
   </children>
</VBox>
