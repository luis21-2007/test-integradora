<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistviewfile.controllers.AppController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <Label text="Gestión de Inventario - Tiendita Local" style="-fx-font-size: 20; -fx-font-weight: bold;" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
            </columnConstraints>

            <children>
                <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="txtCodigo" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="3" />

                <Label text="Precio:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="txtPrecio" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Stock:" GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <TextField fx:id="txtStock" GridPane.rowIndex="1" GridPane.columnIndex="3" />

                <Label text="Categoría:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="txtCategoria" promptText="Ej: Lácteos, Limpieza..." GridPane.rowIndex="2" GridPane.columnIndex="1" />
            </children>
        </GridPane>

        <HBox spacing="10">
            <children>
                <Button onAction="#onAgregar" text="Guardar Producto" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
                <Button   onAction="#onEliminar" text="Eliminar Seleccionado" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
            </children>
        </HBox>

        <Separator />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Buscar:" style="-fx-font-weight: bold;" />
            <TextField fx:id="txtBusqueda" promptText="Filtrar por nombre o código..." HBox.hgrow="ALWAYS" />
        </HBox>

        <TableView fx:id="tableProductos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCodigo" prefWidth="100.0" text="Código" />
                <TableColumn fx:id="colNombre" prefWidth="180.0" text="Nombre" />
                <TableColumn fx:id="colPrecio" prefWidth="100.0" text="Precio ($)" />
                <TableColumn fx:id="colStock" prefWidth="80.0" text="Stock" />
                <TableColumn fx:id="colCat" prefWidth="150.0" text="Categoría" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label fx:id="lblMsg" style="-fx-text-fill: #7f8c8d;" />
    </children>
</VBox>