<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="15" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistviewfile.controllers.AppController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <children>
        <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Gestión de Inventario - Tiendita Local" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
            </columnConstraints>

            <children>
                <Label text="Código:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtCodigo" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Nombre:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtPrecio" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Stock:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="txtStock" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Label text="Categoría:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" promptText="Seleccione una categoría..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <HBox spacing="10">
            <children>
                <Button onAction="#onAgregar" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Guardar " />
                <Button onAction="#onEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Eliminar " />
            <Button onAction="#onEditar" style="-fx-background-color: #000000; -fx-text-fill: white ;" text="Editar" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-weight: bold;" text="Buscar:" />
            <TextField fx:id="txtBusqueda" promptText="Filtrar por nombre o código..." />
        </HBox>

        <Separator />

        <TableView fx:id="tableProductos" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCodigo" prefWidth="100.0" text="Código" />
                <TableColumn fx:id="colNombre" prefWidth="180.0" text="Nombre" />
                <TableColumn fx:id="colPrecio" prefWidth="100.0" text="Precio ($)" />
                <TableColumn fx:id="colStock" prefWidth="80.0" text="Stock" />
                <TableColumn fx:id="colCat" prefWidth="150.0" text="Categoría" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Label fx:id="lblMsg" style="-fx-text-fill: #7f8c8d;" />
    </children>
</VBox>
