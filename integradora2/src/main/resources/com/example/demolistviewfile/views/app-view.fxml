<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="500.0" prefWidth="600.0" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistviewfile.controllers.AppController">
    <children>
        <Label text="Registro de Personas" style="-fx-font-size: 18; -fx-font-weight: bold;" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Nombre:" GridPane.rowIndex="0" />
                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Email:" GridPane.rowIndex="1" />
                <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Edad:" GridPane.rowIndex="2" />
                <TextField fx:id="txtedad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </children>
        </GridPane>

        <HBox spacing="10">
            <children>
                <Button mnemonicParsing="false" onAction="#onAddPerson" text="Agregar Persona" />
                <Button mnemonicParsing="false" onAction="#onReload" text="Recargar Tabla" />
            </children>
        </HBox>

        <TableView fx:id="tableView" prefHeight="250.0" prefWidth="580.0">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="150.0" text="Nombre" />
                <TableColumn fx:id="colEmail" prefWidth="200.0" text="Correo Electrónico" />
                <TableColumn fx:id="colEdad" prefWidth="100.0" text="Edad" />
            </columns>
        </TableView>

        <Label fx:id="lblMsg" />
    </children>
</VBox>